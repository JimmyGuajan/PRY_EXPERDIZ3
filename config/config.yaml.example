# Configuración de Azure OpenAI
# Copia este archivo a config.yaml y completa con tus credenciales reales
# NOTA: config.yaml está en .gitignore para proteger tus credenciales

azure_openai:
  api_key: "tu_api_key_aqui"
  api_endpoint: "https://openaiinteligenciainformacion.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2024-08-01-preview"
  deployment_name: "gpt-4o"
  api_version: "2024-08-01-preview"

# Configuración de la aplicación
app:
  max_file_size_mb: 50
  allowed_extensions: [".xlsx", ".xls", ".csv"]
  temperature: 0.7
  max_tokens: 2000
